{
  "name": "pg-hybrid-rag",
  "version": "0.2.4",
  "description": "Hybrid RAG search pipeline (vector + trigram + FTS) with Postgres-native stemming and RRF fusion",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./sql/*": "./sql/*"
  },
  "files": ["dist", "sql", "README.md"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepublishOnly": "bun run typecheck && bun run lint && bun test && bun run build",
    "release": "bun run prepublishOnly && npm publish"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/bun": "^1.3.11",
    "postgres": "^3.4.8",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {},
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  }
}
