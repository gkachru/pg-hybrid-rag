# PostgreSQL — used by docker-compose (must have pgvector + vchord + pg_textsearch + pg_trgm + pg_bigm)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=postgres

# Playground DATABASE_URL — copy this file to the project root as .env so bun picks it up
DATABASE_URL=postgresql://user:password@localhost:5432/postgres

# Embedding API (OpenAI-compatible endpoint)
# See docker-compose.yml for self-hosting with HuggingFace TEI
EMBEDDING_BASE_URL=http://localhost:3333/v1
EMBEDDING_API_KEY=your-api-key
EMBEDDING_MODEL=intfloat/multilingual-e5-small
