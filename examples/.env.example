# PostgreSQL — used by docker-compose and to build DATABASE_URL for the playground
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=postgres

# Embedding API (OpenAI-compatible endpoint)
# See docker-compose.yml for self-hosting with HuggingFace TEI
EMBEDDING_BASE_URL=http://localhost:3333/v1
EMBEDDING_API_KEY=your-api-key
EMBEDDING_MODEL=intfloat/multilingual-e5-small
