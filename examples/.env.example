# PostgreSQL — used by docker-compose and to build DATABASE_URL for the playground
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=postgres

# Embedding API (OpenAI-compatible endpoint)
# See docker-compose.yml for self-hosting with HuggingFace TEI
EMBEDDING_BASE_URL=http://localhost:3333/v1
EMBEDDING_API_KEY=your-api-key
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Reranker API (HuggingFace TEI cross-encoder /rerank endpoint) — optional.
# Set all three to enable cross-encoder reranking in the playground.
RERANKER_BASE_URL=http://localhost:3334
RERANKER_API_KEY=your-reranker-api-key
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Production Thai word segmenter sidecar (examples/thai-segmenter). Optional — only needed for
# Thai content. Host port from docker-compose.yml (8100 → container 8000).
THAI_SEGMENTER_URL=http://localhost:8100
